

<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>당근 개선안 프로토타입</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap');
  * { margin:0; padding:0; box-sizing:border-box; }

  body {
    font-family: 'Noto Sans KR', sans-serif;
    background: #F0EDE4;
    padding: 48px 32px;
  }

  h1 {
    text-align: center;
    font-size: 22px;
    font-weight: 900;
    color: #1A1A1A;
    margin-bottom: 8px;
  }
  .page-sub {
    text-align: center;
    font-size: 13px;
    color: #888;
    margin-bottom: 48px;
  }
  .page-sub span { color: #FF6F0F; font-weight: 700; }

  /* 섹션 타이틀 */
  .section-title {
    font-size: 14px;
    font-weight: 800;
    color: #1A1A1A;
    margin: 48px 0 20px;
    padding-left: 12px;
    border-left: 4px solid #FF6F0F;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-title .p-badge {
    background: #FF6F0F;
    color: white;
    font-size: 10px;
    font-weight: 800;
    padding: 2px 8px;
    border-radius: 3px;
  }
  .section-title .p-badge.p2 { background: #FF9A55; }
  .section-title .p-badge.p3 { background: #3B82F6; }
  .section-title .p-badge.p4 { background: #8B5CF6; }
  .section-title .p-badge.p5 { background: #2DBB6E; }
  .section-title .p-badge.p6 { background: #F59E0B; }

  /* 스크린 컨테이너 */
  .screens {
    padding: 16px 12px;
    display: flex;
    gap: 24px;
    flex-wrap: nowrap;
    overflow-x: auto;
    padding-bottom: 12px;
  }
  .screen-wrap {
    padding: 16px 14px 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }
  .screen-label {
    font-size: 11px;
    font-weight: 700;
    color: #888;
    text-align: center;
  }

  /* 폰 프레임 */
  .phone {
    position: relative;
    flex-shrink: 0;
    width: 220px;
    height: 440px;
    margin: 14px 14px;
  }
  /* 검정 베젤 프레임 */
  .phone::before {
    content: '';
    position: absolute;
    inset: -10px;
    border-radius: 36px;
    border: 10px solid #1A1A1A;
    box-shadow: 0 0 0 1.5px #555, 0 16px 40px rgba(0,0,0,0.30);
    pointer-events: none;
    z-index: 10;
  }
  .phone-inner {
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 22px;
    background: white;
    scrollbar-width: none;
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .phone-inner::-webkit-scrollbar { display: none; }

  /* 상단 노치 */
  .notch {
    display: none; /* phone::before로 대체 */
  }
  /* 다이나믹 아일랜드 스타일 노치 */
  .phone::after {
    content: '';
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 56px;
    height: 14px;
    background: #1A1A1A;
    border-radius: 8px;
    z-index: 20;
    pointer-events: none;
  }

  /* 앱 공통 */
  .app-header {
    background: white;
    padding: 28px 14px 8px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid #F0F0F0;
    position: sticky;
    top: 0;
    z-index: 5;
  }
  .app-header .back { font-size: 16px; color: #1A1A1A; }
  .app-header .title { font-size: 13px; font-weight: 700; color: #1A1A1A; }
  .app-header .more { font-size: 16px; color: #1A1A1A; }

  /* 당근 네비 탭 */
  .app-nav {
    background: white;
    border-top: 1px solid #F0F0F0;
    display: flex;
    padding: 6px 0 10px;
    flex-shrink: 0;
  }
  .nav-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    font-size: 8px;
    color: #C0C0C0;
  }
  .nav-item.active { color: #FF6F0F; }
  .nav-icon { font-size: 16px; }

  .app-body {
    padding: 0 0 8px;
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: none;
  }
  .app-body::-webkit-scrollbar { display: none; }

  /* 프로필 섹션 */
  .profile-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
  }
  .avatar {
    width: 44px; height: 44px;
    border-radius: 50%;
    background: #FFD4A8;
    display: flex; align-items: center; justify-content: center;
    font-size: 20px;
    flex-shrink: 0;
  }
  .profile-info { flex: 1; }
  .profile-name { font-size: 13px; font-weight: 700; color: #1A1A1A; }
  .profile-location { font-size: 10px; color: #888; margin-top: 1px; }

  /* 매너온도 */
  .manner-temp {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-top: 3px;
  }
  .temp-num { font-size: 12px; font-weight: 800; color: #FF6F0F; }
  .temp-bar {
    flex: 1;
    height: 4px;
    background: #F0F0F0;
    border-radius: 2px;
    overflow: hidden;
  }
  .temp-fill { height: 100%; background: linear-gradient(90deg, #FF6F0F, #FFB07A); border-radius: 2px; }
  .temp-icon { font-size: 10px; }

  /* 배지/태그 */
  .badge-row { display: flex; gap: 4px; flex-wrap: wrap; padding: 0 14px 10px; }
  .badge {
    font-size: 9px;
    font-weight: 600;
    padding: 3px 7px;
    border-radius: 3px;
    border: 1px solid;
  }
  .badge-red { background: #FEECEC; color: #E84040; border-color: #F5A0A0; }
  .badge-or  { background: #FFF3EB; color: #FF6F0F; border-color: #FFD4A8; }
  .badge-gn  { background: #EDFBF3; color: #2DBB6E; border-color: #A0DDB8; }
  .badge-gy  { background: #F5F5F5; color: #666; border-color: #DDD; }
  .badge-bl  { background: #EFF6FF; color: #3B82F6; border-color: #BFDBFE; }

  /* 정보 카드 */
  .info-card {
    margin: 8px 14px;
    background: #FFF8F5;
    border: 1px solid #FFE0CC;
    border-radius: 8px;
    padding: 10px 12px;
  }
  .info-card-title { font-size: 10px; font-weight: 700; color: #FF6F0F; margin-bottom: 6px; }
  .info-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 3px 0;
    border-bottom: 1px solid #FFE8D8;
    font-size: 10px;
    color: #3A3A3A;
  }
  .info-row:last-child { border: none; }
  .info-val { font-weight: 700; }
  .info-val.red { color: #E84040; }
  .info-val.gn  { color: #2DBB6E; }
  .info-val.or  { color: #FF6F0F; }

  /* 알림 배너 */
  .alert-banner {
    margin: 8px 14px;
    background: #FEECEC;
    border: 1px solid #F5A0A0;
    border-radius: 8px;
    padding: 10px 12px;
    display: flex;
    gap: 8px;
    align-items: flex-start;
  }
  .alert-icon { font-size: 14px; flex-shrink: 0; }
  .alert-text { font-size: 10px; color: #C0392B; line-height: 1.5; }
  .alert-text strong { font-weight: 700; display: block; margin-bottom: 2px; }

  .success-banner {
    margin: 8px 14px;
    background: #EDFBF3;
    border: 1px solid #A0DDB8;
    border-radius: 8px;
    padding: 10px 12px;
    display: flex;
    gap: 8px;
    align-items: flex-start;
  }
  .success-text { font-size: 10px; color: #1A7A40; line-height: 1.5; }
  .success-text strong { font-weight: 700; display: block; margin-bottom: 2px; }

  /* 섹션 헤더 */
  .sec-head {
    font-size: 11px;
    font-weight: 700;
    color: #888;
    padding: 10px 14px 4px;
  }

  /* 버튼 */
  .btn-or {
    margin: 8px 14px;
    background: #FF6F0F;
    color: white;
    font-size: 11px;
    font-weight: 700;
    padding: 10px;
    border-radius: 6px;
    text-align: center;
  }
  .btn-outline {
    margin: 4px 14px;
    border: 1.5px solid #FF6F0F;
    color: #FF6F0F;
    font-size: 11px;
    font-weight: 700;
    padding: 9px;
    border-radius: 6px;
    text-align: center;
  }
  .btn-gray {
    margin: 4px 14px;
    background: #F5F5F5;
    color: #666;
    font-size: 11px;
    font-weight: 700;
    padding: 10px;
    border-radius: 6px;
    text-align: center;
  }

  /* 구분선 */
  .divider { height: 6px; background: #F5F5F5; margin: 8px 0; }
  .thin-divider { height: 1px; background: #F0F0F0; margin: 0 14px; }

  /* 아이템 행 */
  .item-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    border-bottom: 1px solid #F8F8F8;
  }
  .item-icon { font-size: 18px; width: 24px; text-align: center; flex-shrink: 0; }
  .item-text { flex: 1; }
  .item-title { font-size: 11px; font-weight: 600; color: #1A1A1A; }
  .item-sub { font-size: 9px; color: #888; margin-top: 1px; }
  .item-right { font-size: 10px; color: #CCC; }

  /* 채팅 버블 */
  .chat-wrap { padding: 10px 14px; display: flex; flex-direction: column; gap: 8px; }
  .bubble-row { display: flex; gap: 6px; align-items: flex-end; }
  .bubble-row.me { flex-direction: row-reverse; }
  .bubble-avatar { width: 24px; height: 24px; border-radius: 50%; background: #FFD4A8; display: flex; align-items: center; justify-content: center; font-size: 12px; flex-shrink: 0; }
  .bubble {
    max-width: 130px;
    padding: 7px 10px;
    border-radius: 12px;
    font-size: 10px;
    line-height: 1.5;
    color: #1A1A1A;
    background: #F0F0F0;
  }
  .bubble.me { background: #FF6F0F; color: white; border-radius: 12px 12px 2px 12px; }
  .bubble.other { border-radius: 12px 12px 12px 2px; }
  .bubble-time { font-size: 8px; color: #BBB; }

  /* 경고 버블 */
  .warn-bubble {
    background: #FFF3EB;
    border: 1px solid #FFD4A8;
    border-radius: 8px;
    padding: 8px 10px;
    font-size: 9px;
    color: #C05A00;
    line-height: 1.5;
    display: flex;
    gap: 6px;
  }

  /* 택배 상태 */
  .track-step {
    display: flex;
    gap: 10px;
    padding: 6px 14px;
    align-items: flex-start;
  }
  .step-dot-wrap { display: flex; flex-direction: column; align-items: center; }
  .step-dot { width: 10px; height: 10px; border-radius: 50%; background: #DDD; flex-shrink: 0; }
  .step-dot.active { background: #FF6F0F; }
  .step-dot.done { background: #2DBB6E; }
  .step-line { width: 1px; height: 18px; background: #E0E0E0; }
  .step-content { flex: 1; padding-bottom: 8px; }
  .step-title { font-size: 10px; font-weight: 600; color: #1A1A1A; }
  .step-title.dim { color: #CCC; }
  .step-sub { font-size: 9px; color: #888; margin-top: 1px; }

  /* 상품 카드 미니 */
  .product-mini {
    display: flex;
    gap: 10px;
    padding: 10px 14px;
    border-bottom: 1px solid #F8F8F8;
    align-items: center;
  }
  .product-img {
    width: 48px; height: 48px;
    border-radius: 6px;
    background: #F0F0F0;
    display: flex; align-items: center; justify-content: center;
    font-size: 22px;
    flex-shrink: 0;
  }
  .product-info { flex: 1; }
  .product-name { font-size: 11px; font-weight: 600; color: #1A1A1A; }
  .product-price { font-size: 12px; font-weight: 800; color: #1A1A1A; margin-top: 2px; }
  .product-sub { font-size: 9px; color: #888; margin-top: 1px; }

  /* 온도 미터 */
  .temp-meter {
    margin: 8px 14px;
    background: #F8F8F8;
    border-radius: 8px;
    padding: 12px;
  }
  .temp-meter-title { font-size: 10px; font-weight: 700; color: #666; margin-bottom: 8px; }
  .temp-bar-big { height: 8px; background: #E8E8E8; border-radius: 4px; overflow: hidden; margin-bottom: 4px; }
  .temp-bar-fill { height: 100%; border-radius: 4px; }
  .temp-labels { display: flex; justify-content: space-between; font-size: 8px; color: #BBB; }
  .temp-score { text-align: center; margin-top: 8px; font-size: 22px; font-weight: 900; color: #FF6F0F; }
  .temp-score-label { text-align: center; font-size: 9px; color: #888; margin-top: 2px; }

  /* 후기 별점 */
  .review-section { padding: 10px 14px; }
  .review-q { font-size: 11px; font-weight: 700; color: #1A1A1A; margin-bottom: 8px; }
  .stars { display: flex; gap: 4px; margin-bottom: 8px; }
  .star { font-size: 20px; cursor: pointer; }
  .review-tags { display: flex; flex-wrap: wrap; gap: 4px; margin-bottom: 8px; }
  .review-tag {
    font-size: 10px; padding: 4px 9px;
    border-radius: 14px; border: 1px solid #E0E0E0;
    color: #666; background: white;
  }
  .review-tag.sel { border-color: #FF6F0F; color: #FF6F0F; background: #FFF3EB; }

  /* 결제 요약 */
  .pay-summary { margin: 8px 14px; }
  .pay-row {
    display: flex; justify-content: space-between;
    font-size: 10px; color: #666;
    padding: 4px 0; border-bottom: 1px solid #F5F5F5;
  }
  .pay-row.total { font-size: 12px; font-weight: 800; color: #1A1A1A; border: none; padding-top: 8px; }

  /* 검색바 */
  .search-bar {
    margin: 8px 14px;
    background: #F5F5F5;
    border-radius: 8px;
    padding: 8px 12px;
    font-size: 11px;
    color: #BBB;
    display: flex; align-items: center; gap: 6px;
  }

  /* 체크박스 항목 */
  .check-item {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 14px;
    border-bottom: 1px solid #F8F8F8;
    font-size: 11px; color: #1A1A1A;
  }
  .checkbox { width: 16px; height: 16px; border-radius: 3px; border: 1.5px solid #DDD; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
  .checkbox.checked { background: #FF6F0F; border-color: #FF6F0F; color: white; font-size: 10px; }

  /* 약속 카드 */
  .appt-card {
    margin: 8px 14px;
    background: #FFF8F5;
    border: 1px solid #FFE0CC;
    border-radius: 8px;
    padding: 10px 12px;
  }
  .appt-title { font-size: 11px; font-weight: 700; color: #1A1A1A; margin-bottom: 6px; }
  .appt-row { display: flex; align-items: center; gap: 6px; font-size: 10px; color: #555; padding: 3px 0; }
  .appt-icon { font-size: 12px; }

  /* 헤더 탭 */
  .header-tab {
    display: flex;
    border-bottom: 1px solid #F0F0F0;
  }
  .h-tab {
    flex: 1; text-align: center;
    font-size: 11px; font-weight: 500;
    padding: 9px 0; color: #BBB;
    border-bottom: 2px solid transparent;
  }
  .h-tab.active { color: #FF6F0F; border-color: #FF6F0F; font-weight: 700; }

  /* 바로구매 단계 */
  .step-flow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    padding: 12px 14px;
    background: #F8F8F8;
    margin: 8px 14px;
    border-radius: 8px;
  }
  .flow-step { text-align: center; }
  .flow-num {
    width: 22px; height: 22px; border-radius: 50%;
    background: #E0E0E0; color: #888;
    font-size: 10px; font-weight: 700;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 4px;
  }
  .flow-num.active { background: #FF6F0F; color: white; }
  .flow-num.done { background: #2DBB6E; color: white; }
  .flow-label { font-size: 8px; color: #888; }
  .flow-label.active { color: #FF6F0F; font-weight: 700; }
  .flow-arrow { font-size: 10px; color: #DDD; margin: 0 4px; padding-bottom: 16px; }

  /* 비용 고지 박스 */
  .cost-box {
    margin: 8px 14px;
    border: 1.5px solid #FFD4A8;
    border-radius: 8px;
    overflow: hidden;
  }
  .cost-box-head { background: #FF6F0F; padding: 6px 12px; font-size: 10px; font-weight: 700; color: white; }
  .cost-box-body { padding: 8px 12px; background: #FFF8F5; }
  .cost-row { display: flex; justify-content: space-between; font-size: 10px; color: #555; padding: 3px 0; }
  .cost-total { display: flex; justify-content: space-between; font-size: 11px; font-weight: 800; color: #1A1A1A; padding: 6px 0 2px; border-top: 1px dashed #FFD4A8; margin-top: 4px; }

  /* 신고 폼 */
  .report-option {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 14px; border-bottom: 1px solid #F8F8F8;
    font-size: 11px; color: #1A1A1A;
  }
  .radio { width: 16px; height: 16px; border-radius: 50%; border: 1.5px solid #DDD; flex-shrink: 0; }
  .radio.sel { border-color: #FF6F0F; background: radial-gradient(circle, #FF6F0F 40%, white 42%); }

  /* 사기 경보 */
  .fraud-alert {
    margin: 8px 14px;
    background: #FFF3EB;
    border: 1.5px solid #FFB07A;
    border-radius: 8px;
    padding: 10px 12px;
  }
  .fraud-title { font-size: 11px; font-weight: 800; color: #C05A00; margin-bottom: 4px; display: flex; align-items: center; gap: 4px; }
  .fraud-item { font-size: 9px; color: #7A3500; line-height: 1.7; }

  /* 온보딩 */
  .onboard-step {
    text-align: center;
    padding: 16px 14px 8px;
  }
  .onboard-icon { font-size: 36px; margin-bottom: 10px; }
  .onboard-title { font-size: 13px; font-weight: 800; color: #1A1A1A; margin-bottom: 6px; line-height: 1.4; }
  .onboard-desc { font-size: 10px; color: #666; line-height: 1.65; }

  /* 도트 인디케이터 */
  .dots { display: flex; justify-content: center; gap: 4px; padding: 8px; }
  .dot { width: 5px; height: 5px; border-radius: 50%; background: #DDD; }
  .dot.active { background: #FF6F0F; width: 14px; border-radius: 3px; }

  .page-break {
    height: 2px;
    background: linear-gradient(90deg, transparent, #DDD8C8, transparent);
    margin: 48px 0 0;
  }
</style>
</head>
<body>

<h1>🥕 당근 마켓 개선안 프로토타입</h1>
<div class="page-sub">P1~P6 개선안 · <span>모바일 앱 스타일</span> · 당근 앱 UX 기반</div>

<!-- ═══════════ P1: 노쇼 제재 ═══════════ -->
<div class="section-title">
  <span class="p-badge">P1</span> 노쇼 제재 시스템 — 이력 공개 · 계정 제한 · 예약금 · 자동 알림
</div>
<div class="screens">

  <!-- 1-1: 프로필에 노쇼 이력 공개 -->
  <div class="screen-wrap">
    <div class="phone">
      <div class="notch"></div>
      <div class="phone-inner">
        <div class="app-header">
          <span class="back">←</span>
          <span class="title">판매자 프로필</span>
          <span class="more">⋯</span>
        </div>
        <div class="app-body">
          <div class="profile-row">
            <div class="avatar">😊</div>
            <div class="profile-info">
              <div class="profile-name">당근마켓유저</div>
              <div class="profile-location">📍 마포구 · 인증됨</div>
              <div class="manner-temp">
                <span class="temp-num">36.5°</span>
                <div class="temp-bar"><div class="temp-fill" style="width:37%"></div></div>
                <span class="temp-icon">🌡️</span>
              </div>
            </div>
          </div>
          <div class="badge-row">
            <span class="badge badge-gn">거래 완료 12회</span>
            <span class="badge badge-red">노쇼 2회 ⚠️</span>
            <span class="badge badge-gy">응답률 72%</span>
          </div>
